{# ── Observability ── #}
<section class="content-block" id="observability">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-12">
                <span class="section-label">Observability</span>
                <h2 class="fw-bold mb-3">Logs, telemetry, and safe failures</h2>
                <p class="text-muted mb-4">
                    Production errors render Twig (Plates) error templates per status code, then fall back to
                    plain PHP views in <code>resources/views/errors/fallback/</code> if Twig (Plates) is unavailable.
                </p>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="feature-card p-4 h-100 mb-0">
                            <i class="bi bi-file-earmark-text feature-icon"></i>
                            <h5 class="fw-bold">Rotating logs</h5>
                            <p class="text-muted small mb-0">Monolog → <code>storage/logs/app-*.log</code> with level and retention from config.</p>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="feature-card p-4 h-100 mb-0">
                            <i class="bi bi-activity feature-icon"></i>
                            <h5 class="fw-bold">Lifecycle telemetry</h5>
                            <p class="text-muted small mb-0">Provider awakening, template render, DB queries — recorded by <code>TelemetryCollector</code> when enabled.</p>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="feature-card p-4 h-100 mb-0">
                            <i class="bi bi-shield-check feature-icon"></i>
                            <h5 class="fw-bold">Safe failures</h5>
                            <p class="text-muted small mb-0">
                                Whoops in dev; production Twig (Plates) error pages per status code with PHP fallbacks in
                                <code>resources/views/errors/fallback/</code> — no stack traces leaked to users.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

