{% extends '@frontend/layouts/base.twig' %}

{% block title %}Better Solutions For Your Business{% endblock %}
{% block body_class %}index-page{% endblock %}

{% set header_class = 'fixed-top' %}
{% set nav_active = 'home' %}

{% block body %}
    <section id="hero" class="hero section dark-background">
        <div class="container">
            <div class="row gy-4">
                <div class="col-lg-6 order-2 order-lg-1 d-flex flex-column justify-content-center" data-aos="zoom-out">
                    <h1>Better Solutions For Your Business</h1>
                    <p>We are team of talented designers making websites with Bootstrap</p>
                    <div class="d-flex">
                        <a href="#about" class="btn-get-started">Get Started</a>
                    </div>
                    <div class="mt-4">
                        <h2 class="h5 text-white-50">Stack test links</h2>
                        <ul class="list-unstyled mb-0">
                            <li><a href="{{ uri('test.errors') }}" class="link-light fw-semibold">Error handling playground</a> — <code>/test/errors</code></li>
                            <li><a href="{{ uri('test.user', {id: 42}) }}" class="link-light">Casting (int route param)</a> — <code>/test/user/42</code></li>
                            <li><a href="{{ uri('test.hello', {name: 'world'}) }}" class="link-light">Resolver chain</a> — <code>/test/hello/world</code></li>
                            <li><a href="{{ uri('api.ping') }}" class="link-light">API ping</a> — <code>/api/ping</code></li>
                            <li>API JSON echo — <code>curl -X POST -H "Content-Type: application/json" -d '{"name":"Ann"}' {{ uri('api.echo') }}</code></li>
                            <li><a href="{{ uri('test.db') }}" class="link-light">Database (Eloquent)</a> — <code>/test/db</code></li>
                            <li>DataMasker — validation log masks email (see <code>storage/logs/validation*.log</code> after form submit)</li>
                            <li><a href="{{ uri('test.http_error') }}" class="link-light">HTTP error (503)</a></li>
                            <li><a href="{{ uri('test.boom') }}" class="link-light">Server error (500)</a></li>
                            <li><a href="/unknown-url" class="link-light">Not found (404)</a></li>
                        </ul>
                        <div class="mt-4 p-3 rounded border border-secondary border-opacity-50 bg-dark bg-opacity-25">
                            <h3 class="h6 text-white-50 mb-3">FormRequest test</h3>
                            {% if flashes is defined and flashes.error is defined %}
                                {% for message in flashes.error %}
                                    <div class="alert alert-danger py-2 small mb-2" role="alert">{{ message }}</div>
                                {% endfor %}
                            {% endif %}
                            <form method="post" action="{{ uri('test.echo') }}" class="row g-2">
                                {% if csrf_token is defined %}
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                {% endif %}
                                <div class="col-md-6">
                                    <label for="echo-name" class="form-label text-white-50 small mb-1">Name</label>
                                    <input type="text" class="form-control form-control-sm{% if errors.name is defined %} is-invalid{% endif %}" id="echo-name" name="name" value="{{ old.name|default('') }}" placeholder="Ann" autocomplete="name">
                                    {% if errors.name is defined %}
                                        <div class="invalid-feedback d-block">
                                            {% for rule, message in errors.name %}
                                                {{ message }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="col-md-6">
                                    <label for="echo-email" class="form-label text-white-50 small mb-1">Email</label>
                                    <input type="email" class="form-control form-control-sm{% if errors.email is defined %} is-invalid{% endif %}" id="echo-email" name="email" value="{{ old.email|default('') }}" placeholder="ann@example.com" autocomplete="email">
                                    {% if errors.email is defined %}
                                        <div class="invalid-feedback d-block">
                                            {% for rule, message in errors.email %}
                                                {{ message }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-outline-light btn-sm mt-1">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 order-1 order-lg-2 hero-img" data-aos="zoom-out" data-aos-delay="200">
                    <img src="/assets/frontend/img/hero-img.png" class="img-fluid animated" alt="">
                </div>
            </div>
        </div>
    </section>
{% endblock %}
