                <tbody>
                    <tr>
                        <td><code>route:list</code></td>
                        <td class="text-muted">List registered routes, methods, and names</td>
                    </tr>
                    <tr>
                        <td><code>view:clear</code></td>
                        <td class="text-muted">Clear compiled Twig cache under <code>storage/cache/views</code></td>
                    </tr>
                    <tr>
                        <td><code>db:migrate</code></td>
                        <td class="text-muted">Run pending migrations from config registry</td>
                    </tr>
                    <tr>
                        <td><code>db:rollback</code></td>
                        <td class="text-muted">Rollback the last migration batch</td>
                    </tr>
                    <tr>
                        <td><code>db:seed</code></td>
                        <td class="text-muted">Execute database seeders</td>
                    </tr>
                    <tr>
                        <td><code>migration:list</code></td>
                        <td class="text-muted">Show migration status</td>
                    </tr>
                    <tr>
                        <td><code>seeders:list</code></td>
                        <td class="text-muted">List available seeders</td>
                    </tr>
                    <tr>
                        <td><code>component:list</code></td>
                        <td class="text-muted">Inspect registered components</td>
                    </tr>
                    <tr>
                        <td><code>component:publish-assets</code></td>
                        <td class="text-muted">Publish component static assets to <code>public/</code></td>
