{% extends '@frontend/layouts/base.twig' %}

{% block title %}FormRequest · Validated{% endblock %}

{% block body %}
    <section class="content-block">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="alert alert-success" role="alert">
                        <h1 class="h4 alert-heading mb-2">FormRequest validation passed</h1>
                        <p class="mb-0">Submitted data was validated by <code>TestEchoRequest</code>.</p>
                    </div>
                    <div class="card shadow-sm">
                        <div class="card-header fw-semibold">Validated input</div>
                        <ul class="list-group list-group-flush">
                            {% for key, value in validated %}
                                <li class="list-group-item d-flex justify-content-between">
                                    <span class="text-muted">{{ key }}</span>
                                    <span class="fw-medium">{{ value }}</span>
                                </li>
                            {% else %}
                                <li class="list-group-item text-muted">No data</li>
                            {% endfor %}
                        </ul>
                    </div>
                    <div class="mt-4">
                        <a href="{{ uri('home') }}" class="btn btn-dark">Back to home</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
