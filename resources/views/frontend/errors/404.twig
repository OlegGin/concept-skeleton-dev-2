{% extends '@frontend/layouts/base.twig' %}

{% block title %}404 · Page Not Found{% endblock %}

{% block body %}
    <section class="content-block text-center">
        <div class="container d-flex align-items-center justify-content-center" style="min-height: 50vh;">
            <div class="text-center">
                <div class="display-1 fw-bold text-danger">404</div>
                <h2 class="display-5 fw-semibold mb-3">Oops! Page not found</h2>
                <p class="lead text-muted mb-4">
                    The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
                </p>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a href="{{ uri('home') }}" class="btn btn-dark btn-lg px-4 gap-3">Return Home</a>
                    <button onclick="history.back()" class="btn btn-outline-secondary btn-lg px-4">Go Back</button>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
