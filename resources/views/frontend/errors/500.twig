{% extends '@frontend/layouts/base.twig' %}

{% block title %}500 · Internal Server Error{% endblock %}

{% block body %}
    <section class="content-block bg-dark text-white text-center">
        <div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
            <div class="text-center">
                <div class="display-1 fw-bold text-muted">500</div>
                <h2 class="display-5 fw-semibold mb-3">Internal Server Error</h2>
                <p class="lead text-muted mb-4">Something went wrong on our end. We are currently working to fix the issue.</p>
                <p class="lead text-muted mb-4">Please try refreshing the page later.</p>
                <a href="{{ uri('home') }}" class="btn btn-dark btn-lg px-5">Back to safety</a>
            </div>
        </div>
    </section>
{% endblock %}
