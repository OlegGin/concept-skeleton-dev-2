{% set dash_active = dash_active|default('dashboard') %}
<!doctype html>
<html lang="uk">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    {% include '@dashboard/partials/_title.twig' with { page_title: block('title') } %}
    {% block meta %}{% endblock %}
    {% include '@dashboard/partials/_head_theme_init.twig' %}
    {% include '@dashboard/partials/_head_assets.twig' %}
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}layout-fixed sidebar-expand-lg bg-body-tertiary{% endblock %}">
<div class="app-wrapper">
    {% include '@dashboard/partials/_header.twig' %}
    {% include '@dashboard/partials/_sidebar.twig' %}

    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-sm-6">
                        <h3 class="mb-0">{% block content_title %}Dashboard{% endblock %}</h3>
                    </div>
                    <div class="col-sm-6">
                        <ol class="breadcrumb float-sm-end">
                            {% block breadcrumbs %}
                                <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">{% block breadcrumb_active %}Dashboard{% endblock %}</li>
                            {% endblock %}
                        </ol>
                    </div>
                </div>
            </div>
        </div>

        <div class="app-content">
            <div class="container-fluid">
                {% include '@dashboard/partials/_flash.twig' %}
                {% block body %}{% endblock %}
            </div>
        </div>
    </main>

    {% include '@dashboard/partials/_footer.twig' %}
</div>

{% include '@dashboard/partials/_scripts.twig' %}
{% block scripts %}{% endblock %}
</body>
</html>
