{% if flashes is defined and flashes|length > 0 %}
<div class="toast-container position-fixed top-0 end-0 p-3 flash-toast-container" style="z-index: 1090">
    {% for type, messages in flashes %}
        {% set toast_type = type == 'error' ? 'danger' : (type == 'notice' ? 'info' : type) %}
        {% for message in messages %}
            <div
                class="toast align-items-center text-bg-{{ toast_type }} border-0 mb-2"
                role="alert"
                aria-live="assertive"
                aria-atomic="true"
                data-bs-autohide="true"
                data-bs-delay="5000"
            >
                <div class="d-flex">
                    <div class="toast-body">{{ message|raw }}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}
</div>
{% endif %}
