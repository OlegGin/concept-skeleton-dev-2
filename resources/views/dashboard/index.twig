{% set dash_active = 'dashboard' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}Dashboard{% endblock %}
{% block content_title %}Dashboard{% endblock %}
{% block breadcrumb_active %}Overview{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-lg-3 col-6">
            <div class="small-box text-bg-primary">
                <div class="inner">
                    <h3>Users</h3>
                    <p>Manage accounts</p>
                </div>
                <i class="small-box-icon bi bi-people-fill"></i>
                <a href="{{ uri('admin.users') }}" class="small-box-footer link-light link-underline-opacity-0 link-underline-opacity-50-hover">
                    Open <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </div>

        <div class="col-lg-3 col-6">
            <div class="small-box text-bg-success">
                <div class="inner">
                    <h3>Site</h3>
                    <p>Public frontend</p>
                </div>
                <i class="small-box-icon bi bi-globe2"></i>
                <a href="{{ uri('home') }}" class="small-box-footer link-light link-underline-opacity-0 link-underline-opacity-50-hover">
                    View <i class="bi bi-arrow-right-circle"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Welcome back{% if auth().user() %}, {{ auth().user().name|default(auth().user().email) }}{% endif %}</h3>
                </div>
                <div class="card-body">
                    <p class="mb-0">Admin panel built on AdminLTE 4 and Concept Core. Use the sidebar to manage users and other modules.</p>
                </div>
                <div class="card-footer">
                    <a href="{{ uri('admin.user.create') }}" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i> Add user
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
