		{
			"name": "Web POST (CSRF)",
			"description": "Web group has `VerifyCsrfTokenMiddleware`. Run **Get CSRF token** first — Postman stores session cookie and sets `csrfToken` collection variable.",
			"item": [
				{
					"name": "Get CSRF token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const html = pm.response.text();",
									"const match = html.match(/name=\"_csrf_token\"\\s+value=\"([^\"]+)\"/);",
									"",
									"pm.test('CSRF token found in HTML', function () {",
									"    pm.expect(match, 'Open GET / and check _csrf_token hidden input').to.not.be.null;",
									"});",
									"",
									"if (match) {",
									"    pm.collectionVariables.set('csrfToken', match[1]);",
									"    console.log('csrfToken saved:', match[1]);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/",
						"description": "Loads home page form with `_csrf_token`. Session cookie is stored automatically by Postman."
					},
					"response": []
				},
				{
					"name": "Echo — valid (FormRequest)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (!pm.collectionVariables.get('csrfToken')) {",
									"    console.warn('Run \"Get CSRF token\" first or set csrfToken manually.');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-CSRF-TOKEN",
								"value": "{{csrfToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Oleh\",\n    \"email\": \"test@example.com\"\n}"
						},
						"url": "{{baseUrl}}/test/echo",
						"description": "FormRequest validation + JSON response when Accept is application/json."
					},
					"response": []
				},
				{
					"name": "Echo — validation error 422",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-CSRF-TOKEN",
								"value": "{{csrfToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\",\n    \"email\": \"not-an-email\"\n}"
						},
						"url": "{{baseUrl}}/test/echo",
						"description": "Expected: 422 JSON with `status: error` and `errors` object."
					},
					"response": []
				},
				{
					"name": "Echo — CSRF missing (419)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Oleh\",\n    \"email\": \"test@example.com\"\n}"
						},
						"url": "{{baseUrl}}/test/echo",
						"description": "No X-CSRF-TOKEN header. Expected: `{ \"code\": 419, \"message\": \"CSRF token mismatch\" }`."
					},
					"response": []
				}
			]
		},
