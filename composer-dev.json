                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-data-masker",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-error-handler-whoops",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-event",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-form-request",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-http",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-json",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-logger-monolog",
