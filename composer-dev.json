                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-view-twig",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Concept\\": "src/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "php-debugbar/php-debugbar": "^3.7"
    },
    "require": {
        "php-concept/core-2": "^1.0",
        "twbs/bootstrap": "^5.3",
        "twbs/bootstrap-icons": "^1.13",
        "php-concept/extension-http": "^1.0",
        "php-concept/extension-casting-valinor": "^1.0",
        "php-concept/extension-form-request": "^1.0",
        "php-concept/extension-validation-rakit": "^1.0",
        "php-concept/extension-view": "^1.0",
        "php-concept/extension-view-twig": "^1.0",
        "php-concept/extension-view-plates": "^1.0",
        "php-concept/extension-session-symfony": "^1.0",
        "php-concept/extension-csrf": "^1.0",
        "php-concept/extension-json": "^1.0",
        "php-concept/extension-data-masker": "^1.0",
        "php-concept/extension-logger-monolog": "^1.0",
        "php-concept/extension-database-eloquent": "^1.0",
        "php-concept/extension-console-symfony": "^1.0",
        "php-concept/extension-error-handler-whoops": "^1.0",
        "php-concept/extension-config": "^1.0",
        "php-concept/extension-path-manager": "^1.0",
        "php-concept/extension-components": "^1.0",
        "php-concept/extension-event": "^1.0",
        "php-concept/extension-telemetry": "^1.0",
        "laminas/laminas-permissions-acl": "^2.18",
        "vlucas/phpdotenv": "^5.6"
    },
    "scripts": {
        "post-install-cmd": [
            "@publish-assets"
        ],
        "post-update-cmd": [
            "@publish-assets"
        ],
        "publish-assets": [
            "mkdir -p public/vendor/bootstrap",
            "cp -R vendor/twbs/bootstrap/dist/. public/vendor/bootstrap/",

            "mkdir -p public/vendor/bootstrap-icons",
            "cp -R vendor/twbs/bootstrap-icons/font/. public/vendor/bootstrap-icons/"
        ],
        "phpstan": "vendor/bin/phpstan analyze --memory-limit=2G",
        "console": "php bin/console.php"
    }
}
