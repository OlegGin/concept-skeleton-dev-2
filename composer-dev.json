            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-path-manager",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-session-symfony",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-telemetry",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-validation-rakit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-view",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/www/concept-extensions/extension-view-plates",
