{
    "name": "php-concept/framework",
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/Http",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/Casting",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/FormRequest",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/Validation",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Concept\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "require": {
        "php-concept/core-2": "@dev",
        "php-concept/extension-http": "@dev",
        "php-concept/extension-casting": "@dev",
        "php-concept/extension-form-request": "@dev",
        "php-concept/extension-validation": "@dev"
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyze --memory-limit=2G"
    }
}
