{% set dash_active = 'settings' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}Settings{% endblock %}
{% block content_title %}Settings{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">Settings</li>
{% endblock %}

{% block body %}
    <div class="row mb-3">
        <div class="col-md-8">
            {% if setting_groups is not empty %}
                <div class="btn-group" role="group" aria-label="Filter by group">
                    <a href="{{ uri('admin.settings') }}" class="btn btn-sm {{ active_group is null ? 'btn-primary' : 'btn-outline-primary' }}">All</a>
                    {% for group in setting_groups %}
                        <a href="{{ uri('admin.settings') ~ '?group=' ~ group.value|url_encode }}" class="btn btn-sm {{ active_group == group.value ? 'btn-primary' : 'btn-outline-primary' }}">{{ group.value }}</a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-primary" href="{{ uri('admin.settings.create') ~ (active_group ? '?group=' ~ active_group|url_encode : '') }}">
                <i class="bi bi-plus-lg me-1"></i> Add setting
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Application settings</h3>
            {% if settings.total > 0 %}
                <span class="badge text-bg-primary ms-2">{{ settings.total }} records</span>
            {% endif %}
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                <tr>
                    <th>Key</th>
                    <th>Group</th>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Description</th>
                    <th>Updated</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for setting in settings %}
                    <tr>
                        <td><a class="" href="{{ uri('admin.settings.edit', {id: setting.id}) }}">{{ setting.setting_key }}</a></td>
                        <td><span class="badge text-bg-secondary">{{ setting.setting_group }}</span></td>
                        <td><span class="badge text-bg-info">{{ setting.data_type }}</span></td>
                        <td class="text-break" style="max-width: 280px;">
                            {% if setting.data_type == 'bool' %}
                                <span class="badge text-bg-{{ setting.setting_value == '1' ? 'success' : 'secondary' }}">{{ setting.setting_value == '1' ? 'true' : 'false' }}</span>
                            {% else %}
                                {{ setting.setting_value|length > 80 ? setting.setting_value|slice(0, 80) ~ '…' : setting.setting_value }}
                            {% endif %}
                        </td>
                        <td class="text-muted">{{ setting.description|default('-') }}</td>
                        <td>{{ setting.updated_at ? setting.updated_at|date('Y-m-d H:i') : '-' }}</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-outline-secondary btn-sm" href="{{ uri('admin.settings.edit', {id: setting.id}) }}">Edit</a>
                            <form action="{{ uri('admin.settings.destroy', {id: setting.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Delete this setting?')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted">No settings found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer clearfix">
            <span class="float-start text-muted">
                Showing <strong>{{ settings.firstItem }}&ndash;{{ settings.lastItem }}</strong> of {{ settings.total }}
            </span>
            {% include '@dashboard/partials/_pagination.twig' with {items: settings} %}
        </div>
    </div>
{% endblock %}
