{% set dash_active = 'acl_matrix' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}ACL Matrix{% endblock %}
{% block content_title %}ACL Matrix{% endblock %}

{% block stylesheets %}
<style>
    .acl-matrix-wrap { overflow-x: auto; }
    .acl-matrix { border-collapse: separate; border-spacing: 0; min-width: 100%; }
    .acl-matrix th, .acl-matrix td { border: 1px solid var(--bs-border-color); padding: 0; vertical-align: middle; }
    .acl-matrix thead th { position: sticky; top: 0; z-index: 2; background: var(--bs-secondary-bg); padding: 10px 12px; font-size: 12px; white-space: nowrap; }
    .acl-matrix tbody th { position: sticky; left: 0; z-index: 1; background: var(--bs-secondary-bg); padding: 10px 14px; text-align: left; white-space: nowrap; font-weight: 600; }
    .acl-matrix thead th a, .acl-matrix tbody th a { color: inherit; text-decoration: none; }
    .acl-matrix thead th a:hover, .acl-matrix tbody th a:hover { text-decoration: underline; }
    .acl-matrix .corner { position: sticky; left: 0; top: 0; z-index: 3; background: var(--bs-secondary-bg); }
    .acl-matrix-cell { min-width: 92px; height: 64px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; padding: 8px; }
    .acl-matrix-cell .state { font-size: 11px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
    .acl-matrix-cell.is-allowed .state { color: var(--bs-success); }
    .acl-matrix-cell.is-denied .state { color: var(--bs-danger); }
    .acl-matrix-cell.is-inherited .state { color: var(--bs-secondary-color); }
    .acl-matrix-actions { display: flex; gap: 4px; flex-wrap: wrap; justify-content: center; }
    .acl-matrix-actions button { border: 0; border-radius: 6px; padding: 2px 6px; font-size: 10px; font-weight: 700; cursor: pointer; }
    .acl-matrix-actions .btn-allow { background: rgba(var(--bs-success-rgb), .15); color: var(--bs-success); }
    .acl-matrix-actions .btn-deny { background: rgba(var(--bs-danger-rgb), .15); color: var(--bs-danger); }
    .acl-matrix-actions .btn-inherit { background: rgba(var(--bs-secondary-rgb), .15); color: var(--bs-secondary-color); }
    .acl-matrix-legend { display: flex; flex-wrap: wrap; gap: 1rem 1.5rem; align-items: center; margin-bottom: 1rem; padding: 0.75rem 1rem; background: var(--bs-secondary-bg); border-radius: var(--bs-border-radius); font-size: 0.8125rem; }
    .acl-matrix-legend-item { display: inline-flex; align-items: center; gap: 0.5rem; }
    .acl-matrix-legend-sample { font-size: 11px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; min-width: 3.5rem; text-align: center; }
    .acl-matrix-legend-sample.is-allowed { color: var(--bs-success); }
    .acl-matrix-legend-sample.is-denied { color: var(--bs-danger); }
    .acl-matrix-legend-sample.is-inherited { color: var(--bs-secondary-color); }
    .acl-matrix-legend-btn { border: 0; border-radius: 6px; padding: 2px 6px; font-size: 10px; font-weight: 700; }
    .acl-matrix-legend-btn.btn-allow { background: rgba(var(--bs-success-rgb), .15); color: var(--bs-success); }
    .acl-matrix-legend-btn.btn-deny { background: rgba(var(--bs-danger-rgb), .15); color: var(--bs-danger); }
    .acl-matrix-legend-btn.btn-inherit { background: rgba(var(--bs-secondary-rgb), .15); color: var(--bs-secondary-color); }
</style>
{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">ACL Matrix</li>
{% endblock %}

{% block body %}
    <div class="acl-matrix-legend" aria-label="Matrix legend">
        <span class="text-muted fw-semibold me-1">Legend:</span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-sample is-allowed">ALLOW</span>
                    <span class="text-muted">explicit allow</span>
                </span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-sample is-denied">DENY</span>
                    <span class="text-muted">explicit deny</span>
                </span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-sample is-inherited">ALLOW</span>
                    <span class="text-muted">inherited allow</span>
                </span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-sample is-inherited">DENY</span>
                    <span class="text-muted">inherited deny</span>
                </span>
        <span class="acl-matrix-legend-item border-start ps-3">
                    <span class="acl-matrix-legend-btn btn-allow">A</span>
                    <span class="text-muted">set allow</span>
                </span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-btn btn-deny">D</span>
                    <span class="text-muted">set deny</span>
                </span>
        <span class="acl-matrix-legend-item">
                    <span class="acl-matrix-legend-btn btn-inherit">—</span>
                    <span class="text-muted">inherit (remove direct rule)</span>
                </span>
    </div>
    <div>
        <form class="row g-3 align-items-end mb-4" method="GET" action="{{ uri('admin.acl.matrix') }}">
            <div class="col-md-4">
                <label class="form-label" for="privilege">Privilege filter</label>
                <select id="privilege" name="privilege" class="form-select">
                    <option value="">— all privileges —</option>
                    {% for item in privileges %}
                        <option value="{{ item.value }}" {{ privilege|default('') == item.value ? 'selected' : '' }}>{{ item.name|capitalize }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-8 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                {% if privilege %}
                    <a class="btn btn-outline-secondary" href="{{ uri('admin.acl.matrix') }}">Clear filter</a>
                {% endif %}
            </div>
        </form>
    </div>
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Resource × Role</h3>
        </div>
        <div class="card-body">
            <div class="acl-matrix-wrap">
                <table class="acl-matrix table mb-0">
                    <thead>
                    <tr>
                        <th class="corner">Resource \ Role</th>
                        {% for role in roles %}
                            <th title="{{ role.name }}">
                                <a href="{{ uri('admin.acl.role.edit', {id: role.id}) }}">{{ role.name }}</a>
                            </th>
                        {% endfor %}
                    </tr>
                    </thead>
                    <tbody>
                    {% for resource in resources %}
                        <tr>
                            <th>
                                <a href="{{ uri('admin.acl.resource.edit', {id: resource.id}) }}">{{ resource.name }}</a>
                            </th>
                            {% for role in roles %}
                                {% set cell = cells[role.id][resource.id] %}
                                {% set explicit = cell.explicit %}
                                {% set allowed = cell.allowed %}
                                <td>
                                    <div class="acl-matrix-cell {{ allowed ? 'is-allowed' : 'is-denied' }} {{ explicit ? '' : 'is-inherited' }}">
                                        <span class="state">
                                            {% if explicit %}
                                                {{ explicit|upper }}
                                            {% elseif allowed %}
                                                ALLOW
                                            {% else %}
                                                DENY
                                            {% endif %}
                                        </span>
                                        <div class="acl-matrix-actions">
                                            <form method="POST" action="{{ uri('admin.acl.matrix.update') }}">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                                <input type="hidden" name="role_id" value="{{ role.id }}">
                                                <input type="hidden" name="resource_id" value="{{ resource.id }}">
                                                <input type="hidden" name="action" value="allow">
                                                {% if privilege %}<input type="hidden" name="privilege" value="{{ privilege }}">{% endif %}
                                                <button type="submit" class="btn-allow" title="Explicit allow">A</button>
                                            </form>
                                            <form method="POST" action="{{ uri('admin.acl.matrix.update') }}">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                                <input type="hidden" name="role_id" value="{{ role.id }}">
                                                <input type="hidden" name="resource_id" value="{{ resource.id }}">
                                                <input type="hidden" name="action" value="deny">
                                                {% if privilege %}<input type="hidden" name="privilege" value="{{ privilege }}">{% endif %}
                                                <button type="submit" class="btn-deny" title="Explicit deny">D</button>
                                            </form>
                                            <form method="POST" action="{{ uri('admin.acl.matrix.update') }}">
                                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                                <input type="hidden" name="role_id" value="{{ role.id }}">
                                                <input type="hidden" name="resource_id" value="{{ resource.id }}">
                                                <input type="hidden" name="action" value="inherit">
                                                {% if privilege %}<input type="hidden" name="privilege" value="{{ privilege }}">{% endif %}
                                                <button type="submit" class="btn-inherit" title="Remove direct rule (inherit)">—</button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            {% endfor %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ roles|length + 1 }}" class="text-center text-muted py-4">No roles or resources. Run the ACL seeder first.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
