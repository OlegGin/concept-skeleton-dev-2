{% set dash_active = 'acl_resources' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}ACL Resources{% endblock %}
{% block content_title %}ACL Resources{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">ACL Resources</li>
{% endblock %}

{% block body %}
    <div class="row mb-3">
        <div class="col-md-8"></div>
        <div class="col-md-4 text-end">
            <a class="btn btn-primary" href="{{ uri('admin.acl.resource.create') }}">
                <i class="bi bi-plus-lg me-1"></i> Add resource
            </a>
        </div>
    </div>

    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title">Filter resources</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="bi bi-dash-lg"></i>
                </button>
            </div>
        </div>
        <form action="{{ uri('admin.acl.resources') }}" method="GET">
            {% include '@acl/admin/partials/_list_sort_hidden_fields.twig' %}
            <div class="card-body">
                <div class="row g-3">
                    {% include '@acl/admin/partials/_name_parent_filter_fields.twig' with {
                        entity_label: 'resource',
                        name_placeholder: 'admin.users'
                    } %}
                </div>
            </div>
            <div class="card-footer text-end">
                <a href="{{ uri('admin.acl.resources') }}" class="btn btn-secondary me-2">Clear filters</a>
                <button type="submit" class="btn btn-primary">Apply filters</button>
            </div>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">All resources</h3>
            {% if resources.total > 0 %}
                <span class="badge text-bg-primary ms-2">{{ resources.total }} records</span>
            {% endif %}
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                <tr>
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.resources', column: 'id', label: 'ID'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.resources', column: 'name', label: 'Name'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.resources', column: 'parent_name', label: 'Parent'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.resources', column: 'children_count', label: 'Children'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.resources', column: 'rules_count', label: 'Rules'} %}
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for resource in resources %}
                    <tr>
                        <td>#{{ resource.id }}</td>
                        <td><a href="{{ uri('admin.acl.resource.edit', {id: resource.id}) }}">{{ resource.name }}</a></td>
                        <td>{{ resource.parent ? resource.parent.name : '—' }}</td>
                        <td>{{ resource.children_count }}</td>
                        <td>{{ resource.rules_count }}</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-outline-secondary btn-sm" href="{{ uri('admin.acl.resource.edit', {id: resource.id}) }}">Edit</a>
                            <form action="{{ uri('admin.acl.resource.destroy', {id: resource.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Delete this resource?')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No resources found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer clearfix">
            <span class="float-start text-muted">
                Showing <strong>{{ resources.firstItem }}&ndash;{{ resources.lastItem }}</strong> of {{ resources.total }}
            </span>
            {% include '@dashboard/partials/_pagination.twig' with {items: resources} %}
        </div>
    </div>
{% endblock %}
