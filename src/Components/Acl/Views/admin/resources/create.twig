{% set dash_active = 'acl_resources' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}New ACL resource{% endblock %}
{% block content_title %}New ACL resource{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item"><a href="{{ uri('admin.acl.resources') }}">ACL Resources</a></li>
    <li class="breadcrumb-item active" aria-current="page">Create</li>
{% endblock %}

{% block body %}
    <div class="card">
        <form action="{{ uri('admin.acl.resource.store') }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="name">Name <span class="text-danger">*</span></label>
                        <input id="name" type="text" name="name" class="form-control {{ errors.name is defined and errors.name ? 'is-invalid' : '' }}" value="{{ old.name|default('') }}" placeholder="admin.users" required>
                        {% include '@dashboard/partials/_field_errors.twig' with { field: 'name' } %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="parent_id">Parent resource</label>
                        <select id="parent_id" name="parent_id" class="form-select">
                            <option value="">— none —</option>
                            {% for parent in resources %}
                                <option value="{{ parent.id }}" {{ old.parent_id|default('') == parent.id ? 'selected' : '' }}>{{ parent.name }}</option>
                            {% endfor %}
                        </select>
                        {% include '@dashboard/partials/_field_errors.twig' with { field: 'parent_id' } %}
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between align-items-center">
                <a href="{{ uri('admin.acl.resources') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary ms-auto">Create resource</button>
            </div>
        </form>
    </div>
{% endblock %}
