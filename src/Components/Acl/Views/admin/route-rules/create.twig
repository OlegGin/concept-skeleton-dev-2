{% set dash_active = 'acl_route_rules' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}New ACL route rule{% endblock %}
{% block content_title %}New ACL route rule{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item"><a href="{{ uri('admin.acl.route-rules') }}">ACL Route Rules</a></li>
    <li class="breadcrumb-item active" aria-current="page">Create</li>
{% endblock %}

{% block body %}
    <div class="card">
        <form action="{{ uri('admin.acl.route-rule.store') }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        {% include '@acl/admin/partials/_route_name_select.twig' with {
                            field_id: 'route_name',
                            label: 'Route name',
                            required: true,
                            route_tree: route_tree,
                            selected: old.route_name|default('')
                        } %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="resource_id">Resource <span class="text-danger">*</span></label>
                        <select id="resource_id" name="resource_id" class="form-select" required>
                            <option value="">— select —</option>
                            {% for resource in resources %}
                                <option value="{{ resource.id }}" {{ old.resource_id|default('') == resource.id ? 'selected' : '' }}>{{ resource.name }}</option>
                            {% endfor %}
                        </select>
                        {% include '@dashboard/partials/_field_errors.twig' with { field: 'resource_id' } %}
                    </div>
                    <div class="col-md-6">
                        {% include '@acl/admin/partials/_privilege_select.twig' with {
                            field_id: 'privilege',
                            privileges: privileges,
                            selected: old.privilege|default(''),
                            empty_label: '— none (resource-level) —'
                        } %}
                    </div>
                    <div class="col-md-6">
                        {% include '@acl/admin/partials/_route_name_select.twig' with {
                            field_id: 'redirect_route_name',
                            field_name: 'redirect_route_name',
                            label: 'Redirect route name',
                            empty_option: '— use config default —',
                            route_tree: route_tree,
                            selected: old.redirect_route_name|default('')
                        } %}
                        <div class="form-text">If empty, the interceptor uses `acl.redirect_route_name` from config.</div>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between align-items-center">
                <a href="{{ uri('admin.acl.route-rules') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary ms-auto">Create route rule</button>
            </div>
        </form>
    </div>
{% endblock %}
