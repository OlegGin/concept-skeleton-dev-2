{% set dash_active = 'acl_route_rules' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}ACL Route Rules{% endblock %}
{% block content_title %}ACL Route Rules{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">ACL Route Rules</li>
{% endblock %}

{% block body %}
    <div class="row mb-3">
        <div class="col-md-8">
            <p class="text-muted mb-0 small">Map named routes to ACL resources and privileges.</p>
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-primary" href="{{ uri('admin.acl.route-rule.create') }}">
                <i class="bi bi-plus-lg me-1"></i> Add route rule
            </a>
        </div>
    </div>

    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title">Filter route rules</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="bi bi-dash-lg"></i>
                </button>
            </div>
        </div>
        <form action="{{ uri('admin.acl.route-rules') }}" method="GET">
            {% include '@acl/admin/partials/_list_sort_hidden_fields.twig' %}
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="filter_route_name">Route name</label>
                        <input id="filter_route_name" type="text" name="route_name" class="form-control" value="{{ filters.route_name|default('') }}" placeholder="admin.users">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="filter_resource_id">Resource</label>
                        <select id="filter_resource_id" name="resource_id" class="form-select">
                            <option value="">— all —</option>
                            {% for resource in resources %}
                                <option value="{{ resource.id }}" {{ filters.resource_id|default('') == resource.id ? 'selected' : '' }}>{{ resource.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="filter_privilege">Privilege</label>
                        <select id="filter_privilege" name="privilege" class="form-select">
                            <option value="">— all —</option>
                            {% for privilege in privileges %}
                                <option value="{{ privilege.value }}" {{ filters.privilege|default('') == privilege.value ? 'selected' : '' }}>{{ privilege.value }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>
            <div class="card-footer text-end">
                <a href="{{ uri('admin.acl.route-rules') }}" class="btn btn-secondary me-2">Clear filters</a>
                <button type="submit" class="btn btn-primary">Apply filters</button>
            </div>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">All route rules</h3>
            {% if rules.total > 0 %}
                <span class="badge text-bg-primary ms-2">{{ rules.total }} records</span>
            {% endif %}
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                <tr>
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.route-rules', column: 'id', label: 'ID'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.route-rules', column: 'route_name', label: 'Route name'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.route-rules', column: 'resource_name', label: 'Resource'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.route-rules', column: 'privilege', label: 'Privilege'} %}
                    {% include '@acl/admin/partials/_sortable_th.twig' with {route: 'admin.acl.route-rules', column: 'redirect_route_name', label: 'Redirect route name'} %}
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for rule in rules %}
                    <tr>
                        <td>#{{ rule.id }}</td>
                        <td><a href="{{ uri('admin.acl.route-rule.edit', {id: rule.id}) }}">{{ rule.route_name }}</a></td>
                        <td>{{ rule.resource ? rule.resource.name : '—' }}</td>
                        <td>{{ rule.privilege ?: '—' }}</td>
                        <td><span class="badge text-bg-secondary">{{ rule.redirect_route_name ?: 'config default' }}</span></td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-outline-secondary btn-sm" href="{{ uri('admin.acl.route-rule.edit', {id: rule.id}) }}">Edit</a>
                            <form action="{{ uri('admin.acl.route-rule.destroy', {id: rule.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Delete this route rule?')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No route rules found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer clearfix">
            <span class="float-start text-muted">
                Showing <strong>{{ rules.firstItem }}&ndash;{{ rules.lastItem }}</strong> of {{ rules.total }}
            </span>
            {% include '@dashboard/partials/_pagination.twig' with {items: rules} %}
        </div>
    </div>
{% endblock %}
