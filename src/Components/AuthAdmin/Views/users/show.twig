{% set dash_active = 'users' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}{{ user.name }}{% endblock %}
{% block content_title %}{{ user.full_name|default(user.name) }}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item"><a href="{{ uri('admin.users') }}">Users</a></li>
    <li class="breadcrumb-item active" aria-current="page">View</li>
{% endblock %}

{% block body %}
    <div class="card card-info card-outline">
        <div class="card-header">
            <h3 class="card-title mb-0">User details</h3>
            <div class="card-tools">
                <a class="btn btn-primary btn-sm" href="{{ uri('admin.user.edit', {id: user.id}) }}">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" value="{{ user.name }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" value="{{ user.email }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <input type="text" class="form-control" value="{{ user.status|upper }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Is Admin</label>
                    <input type="text" class="form-control" value="{{ user.is_admin ? 'YES' : 'NO' }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email Verified At</label>
                    <input type="text" class="form-control" value="{{ user.email_verified_at ? user.email_verified_at|date('Y-m-d H:i') : 'Not verified' }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Verification Token</label>
                    <input type="text" class="form-control" value="{{ user.verification_token }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Password Reset Token</label>
                    <input type="text" class="form-control" value="{{ user.password_reset_token }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Reset Token Expires At</label>
                    <input type="text" class="form-control" value="{{ user.reset_token_expires_at ? user.reset_token_expires_at|date('Y-m-d H:i') : 'None' }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Created At</label>
                    <input type="text" class="form-control" value="{{ user.created_at|date('Y-m-d H:i') }}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Updated At</label>
                    <input type="text" class="form-control" value="{{ user.updated_at|date('Y-m-d H:i') }}" readonly>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
            <form id="delete-form-show" action="{{ uri('admin.user.destroy', {id: user.id}) }}" method="POST" class="mb-0" onsubmit="return confirm('Are you sure you want to delete this user?');">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-outline-danger">Delete</button>
            </form>
            <a href="{{ uri('admin.users') }}" class="btn btn-secondary ms-auto">Back to list</a>
        </div>
    </div>
{% endblock %}
