{% set dash_active = 'users' %}
{% extends '@dashboard/layouts/base.twig' %}

{% block title %}Users{% endblock %}
{% block content_title %}Users{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ uri('admin.dashboard') }}">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">Users</li>
{% endblock %}

{% block body %}
    <div class="row mb-3">
        <div class="col-12 text-end">
            <a class="btn btn-primary" href="{{ uri('admin.user.create') }}">
                <i class="bi bi-person-plus me-1"></i> Add user
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">All users</h3>
            {% if users.total > 0 %}
                <span class="badge text-bg-primary ms-2">{{ users.total }} records</span>
            {% endif %}
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Admin</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Updated At</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>#{{ user.id }}</td>
                        <td><a href="{{ uri('admin.user.edit', {id: user.id}) }}">{{ user.name }}</a></td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% if user.is_admin %}
                                <span class="badge text-bg-primary">Yes</span>
                            {% else %}
                                <span class="badge text-bg-secondary">No</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge text-bg-{{ user.status == 'active' ? 'success' : (user.status == 'blocked' ? 'danger' : 'warning') }}">
                                {{ user.status|upper }}
                            </span>
                        </td>
                        <td>{{ user.created_at ? user.created_at|date('Y-m-d H:i') : '-' }}</td>
                        <td>{{ user.updated_at ? user.updated_at|date('Y-m-d H:i') : '-' }}</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-outline-primary btn-sm" href="{{ uri('admin.user.show', {id: user.id}) }}">View</a>
                            <a class="btn btn-outline-secondary btn-sm" href="{{ uri('admin.user.edit', {id: user.id}) }}">Edit</a>
                            <form action="{{ uri('admin.user.destroy', {id: user.id}) }}" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">No users found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer clearfix">
            <span class="float-start text-muted">
                Showing <strong>{{ users.firstItem }}&ndash;{{ users.lastItem }}</strong> of {{ users.total }}
            </span>
            {% include '@dashboard/partials/_pagination.twig' with {items: users} %}
        </div>
    </div>
{% endblock %}
