{% extends '@dashboard/layouts/auth.twig' %}

{% block title %}Sign in{% endblock %}

{% block body %}
    <p class="login-box-msg">Sign in to open the admin panel</p>

    <form action="{{ uri('admin.login.submit') }}" method="post">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        <div class="input-group mb-3">
            <input
                type="email"
                class="form-control {{ errors.email is defined and errors.email ? 'is-invalid' : '' }}"
                name="email"
                value="{{ old.email|default('') }}"
                placeholder="Email"
                autocomplete="email"
                required
                autofocus
            >
            <div class="input-group-text"><span class="bi bi-envelope"></span></div>
        </div>
        {% include '@dashboard/partials/_field_errors.twig' with { field: 'email' } %}

        <div class="input-group mb-3">
            <input
                type="password"
                class="form-control {{ errors.password is defined and errors.password ? 'is-invalid' : '' }}"
                name="password"
                placeholder="Password"
                autocomplete="current-password"
                required
            >
            <div class="input-group-text"><span class="bi bi-lock-fill"></span></div>
        </div>
        {% include '@dashboard/partials/_field_errors.twig' with { field: 'password' } %}

        <div class="row">
            <div class="col-8">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="remember" value="1" id="remember">
                    <label class="form-check-label" for="remember">Remember me</label>
                </div>
            </div>
            <div class="col-4">
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Sign in</button>
                </div>
            </div>
        </div>
    </form>

    <p class="mb-0 mt-3 text-center">
        <a href="{{ uri('home') }}">Back to site</a>
    </p>
{% endblock %}
