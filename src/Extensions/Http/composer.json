{
    "name": "php-concept/extension-http",
    "description": "Concept HTTP extension — responses, URLs, route introspection",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\Http\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/core-2": "@dev",
        "php-concept/extension-event": "@dev",
        "laminas/laminas-diactoros": "^3.8",
        "league/route": "^6.2",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0",
        "symfony/console": "^7.2|^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
