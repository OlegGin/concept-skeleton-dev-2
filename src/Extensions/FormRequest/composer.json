{
    "name": "php-concept/extension-form-request",
    "description": "Concept FormRequest extension — form request factory and argument resolver",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\FormRequest\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/core-2": "@dev",
        "php-concept/extension-casting-valinor": "@dev",
        "php-concept/extension-validation-rakit": "@dev",
        "php-concept/extension-csrf": "@dev",
        "league/container": "^5.1",
        "psr/http-message": "^2.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../CastingValinor",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../ValidationRakit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Csrf",
            "options": {
                "symlink": true
            }
        }
    ]
}
