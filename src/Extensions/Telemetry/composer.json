{
    "name": "php-concept/extension-telemetry",
    "description": "Concept Telemetry extension — in-request collector and event subscribers",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\Telemetry\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/core-2": "@dev",
        "php-concept/extension-event": "@dev",
        "php-concept/extension-components": "@dev",
        "php-concept/extension-database-eloquent": "@dev",
        "php-concept/extension-form-request": "@dev",
        "php-concept/extension-view": "@dev",
        "league/container": "^5.1",
        "league/event": "^3.0",
        "monolog/monolog": "^3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/Event",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/Components",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/DatabaseEloquent",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/FormRequest",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "src/Extensions/View",
            "options": {
                "symlink": true
            }
        }
    ]
}
