{
    "name": "php-concept/extension-data-masker",
    "description": "Concept DataMasker extension — redact sensitive values in logs and debug output",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\DataMasker\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/extension-event": "@dev",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
