{
    "name": "php-concept/extension-logger-monolog",
    "description": "Concept Logger extension — Monolog rotating file logging with optional data masking",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\LoggerMonolog\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "monolog/monolog": "^3",
        "psr/log": "^3",
        "php-concept/extension-data-masker": "@dev",
        "php-concept/extension-event": "@dev",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../DataMasker",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
