{
    "name": "php-concept/extension-view-plates",
    "description": "Concept View Plates engine — PlatesView implementation",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\ViewPlates\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/core-2": "@dev",
        "php-concept/extension-view": "@dev",
        "php-concept/extension-event": "@dev",
        "league/plates": "^3.6",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../View",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
