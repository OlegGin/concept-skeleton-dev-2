{
    "name": "php-concept/extension-path-manager",
    "description": "Concept PathManager extension — project root and named path map resolution",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\PathManager\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/extension-event": "@dev",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
