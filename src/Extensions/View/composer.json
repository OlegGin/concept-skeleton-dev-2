{
    "name": "php-concept/extension-view",
    "description": "Concept View extension — view contracts, response factory, registries",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Concept\\Extensions\\View\\": "src/"
        }
    },
    "require": {
        "php": "^8.4",
        "php-concept/core-2": "@dev",
        "php-concept/extension-http": "@dev",
        "php-concept/extension-event": "@dev",
        "league/container": "^5.1",
        "psr/event-dispatcher": "^1.0",
        "psr/http-message": "^2.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/www/concept-core-2",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Http",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../Event",
            "options": {
                "symlink": true
            }
        }
    ]
}
